{
  "name": "@poliverai/poliverai",
  "root": "apps/poliverai",
  "sourceRoot": "apps/poliverai/src",
  "projectType": "application",
  "targets": {
    "start": {
      "executor": "@nx/react-native:start",
      "options": {}
    },
    "run-android": {
      "executor": "@nx/react-native:run-android",
      "options": {}
    },
    "run-ios": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node ../../scripts/prepare-and-install.js ios && yarn run ios"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "run-ios-debug-experimental": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "RCT_NEW_ARCH_ENABLED=1 node ../../scripts/prepare-and-install.js ios && RCT_NEW_ARCH_ENABLED=1 npx react-native run-ios --scheme PoliverAI-DebugExperimental --mode DebugExperimental"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "build-android": {
      "executor": "@nx/react-native:build-android",
      "options": {}
    },
    "build-ios": {
      "executor": "@nx/react-native:build-ios",
      "options": {}
    },
    "run-macos": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "sh -lc \"if (grep -q '\"react-native-macos\"' package.json 2>/dev/null || [ -d node_modules/react-native-macos ] || [ -d ../node_modules/react-native-macos ]) && [ -d macos ]; then npx react-native run-macos; else echo 'react-native run-macos not configured: add react-native-macos and initialize the macos/ native project (see https://microsoft.github.io/react-native-macos/).'; fi\""
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "run-windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node ../../scripts/prepare-and-install.js windows && node ../../node_modules/react-native/cli.js run-windows --logging"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "build-macos": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "sh -lc \"if (grep -q '\"react-native-macos\"' package.json 2>/dev/null || [ -d node_modules/react-native-macos ] || [ -d ../node_modules/react-native-macos ]) && [ -d macos ]; then npx react-native build-macos; else echo 'react-native build-macos not configured: add react-native-macos and initialize the macos/ native project.'; fi\""
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "build-windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node ../../scripts/prepare-and-install.js windows && node ../../node_modules/react-native/cli.js build-windows"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "enable-macos": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "echo 'Installing react-native-macos into @poliverai/poliverai (this will modify package.json). Run this locally:'"
          },
          {
            "command": "echo '  cd apps/poliverai && yarn add react-native-macos@latest'"
          },
          {
            "command": "echo 'After install run native setup instructions: https://microsoft.github.io/react-native-macos/'"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "enable-windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "echo 'Installing react-native-windows into @poliverai/poliverai (this will modify package.json). Run this locally:'"
          },
          {
            "command": "echo '  cd apps/poliverai && yarn add react-native-windows@latest'"
          },
          {
            "command": "echo 'After install run native setup instructions: https://microsoft.github.io/react-native-windows/'"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "config": "apps/poliverai/vite.config.ts",
        "buildTarget": "@poliverai/poliverai:build"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "config": "apps/poliverai/vite.config.ts"
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "options": {
        "config": "apps/poliverai/vite.config.ts"
      }
    },
    "run-windows-no-packager": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node ../../scripts/prepare-and-install.js windows && node ../../node_modules/react-native/cli.js run-windows --logging --no-packager"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    },
    "start-metro-windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node ./scripts/start-metro-windows.js"
          }
        ],
        "cwd": "apps/poliverai",
        "parallel": false
      }
    }
  }
}
